@{
    var pageIndex = (int)(ViewData["PageIndex"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var hasPrev = (bool)(ViewData["HasPreviousPage"] ?? false);
    var hasNext = (bool)(ViewData["HasNextPage"] ?? false);
    var filter = ViewData["CurrentFilter"] as string ?? string.Empty;
}

@if (totalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!hasPrev ? "disabled" : "")">
                <a class="page-link" href="?pageNumber=@(pageIndex - 1)&searchString=@filter">Previous</a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == pageIndex ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&searchString=@filter">@i</a>
                </li>
            }

            <li class="page-item @(!hasNext ? "disabled" : "")">
                <a class="page-link" href="?pageNumber=@(pageIndex + 1)&searchString=@filter">Next</a>
            </li>
        </ul>
    </nav>
}
