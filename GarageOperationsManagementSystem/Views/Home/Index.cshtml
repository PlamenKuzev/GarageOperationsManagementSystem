@{
    ViewData["Title"] = "Home Page";
}

<div class="py-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <h1 class="display-5 fw-semibold mb-3">Garage Operations Management System</h1>
            <p class="lead text-muted mb-4">
                Track your repair by issue code, or find the nearest garage on the map.
            </p>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary btn-lg"
                   asp-area="Public"
                   asp-controller="RepairStatus"
                   asp-action="Index">
                    Track repair status
                </a>
                <a class="btn btn-outline-secondary btn-lg"
                   asp-area=""
                   asp-controller="Garages"
                   asp-action="MapView">
                    View garages map
                </a>
            </div>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <div class="col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-2">Demo codes</h2>
                        <p class="text-muted mb-3">Use these in the tracker page (seeded in the database):</p>
                        <ul class="mb-0">
                            <li><strong>DEMO0001</strong> (in progress)</li>
                            <li><strong>DEMO0002</strong> (completed)</li>
                            <li><strong>DEMO0003</strong> (in progress)</li>
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
