@using Microsoft.AspNetCore.Identity
@using GarageOperationsManagementSystem.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home Page";
    var heading = "Garage Operations Management System";
    if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        var displayName = appUser?.FullName is { Length: > 0 }
            ? appUser.FullName
            : appUser?.Email?.Split('@')[0];
        if (displayName is not null)
        {
            heading = $"Welcome, {displayName}!";
        }
    }
}

<div class="py-5 text-center">
    <h1 class="display-5 fw-semibold mb-3">@heading</h1>
    <p class="lead text-muted mb-4">
        Track your repair by issue code, or find the nearest garage on the map.
    </p>
    <div class="d-flex flex-wrap justify-content-center gap-2">
        <a class="btn btn-primary btn-lg"
           asp-area="Public"
           asp-controller="RepairStatus"
           asp-action="Index">
            Track repair status
        </a>
        <a class="btn btn-outline-secondary btn-lg"
           asp-area=""
           asp-controller="Garages"
           asp-action="MapView">
            View garages map
        </a>
    </div>
</div>
