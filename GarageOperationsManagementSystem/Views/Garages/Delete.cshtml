@model GarageOperationsManagementSystem.Models.Garage

@{
    ViewData["Title"] = "Delete Garage";
}

<h2>Delete Garage</h2>
<p class="text-danger">Are you sure you want to delete this garage?</p>

<dl class="row">
    <dt class="col-sm-3">City</dt>
    <dd class="col-sm-9">@Model.City</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Address</dd>

    <dt class="col-sm-3">Capacity</dt>
    <dd class="col-sm-9">@Model.Capacity</dd>

    <dt class="col-sm-3">Work Schedule</dt>
    <dd class="col-sm-9">@Model.WorkSchedule</dd>

    <dt class="col-sm-3">Latitude</dt>
    <dd class="col-sm-9">@Model.Latitude</dd>

    <dt class="col-sm-3">Longitude</dt>
    <dd class="col-sm-9">@Model.Longitude</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</form>
