@model GarageOperationsManagementSystem.Models.RepairOrder

@{
    ViewData["Title"] = "Delete repair order";
}

<h2 class="mb-3">Delete repair order</h2>

<p>Are you sure you want to delete this repair order?</p>

<ul>
    <li>Id: @Model.Id</li>
    <li>Issue code: <code>@Model.IssueCode</code></li>
    <li>Description: @Model.IssueDescription</li>
</ul>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
