@model PaginatedList<GarageOperationsManagementSystem.Models.RepairOrder>

@{
    ViewData["Title"] = "Repair orders";
    var isTrusted = (bool)(ViewData["IsTrusted"] ?? false);
}

<div class="mb-4">
    <h1 class="h3">Repair orders</h1>
    <p class="text-muted mb-0">
        @if (isTrusted)
        {
            <span>All garages — trusted access.</span>
        }
        else
        {
            <span>Your garage only — junior access.</span>
        }
    </p>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <partial name="_SearchFormPartial" />
    <a class="btn btn-primary" asp-action="Create">New repair order</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Issue code</th>
            <th>Car</th>
            <th>Owner</th>
            <th>Garage</th>
            <th>Arrival</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td><code>@order.IssueCode</code></td>
                <td>@order.Car?.Brand @order.Car?.Model</td>
                <td>@order.Car?.Owner?.FullName</td>
                <td>@order.Garage?.City</td>
                <td>@order.ArrivalDate.ToString("dd MMM yyyy")</td>
                <td>
                    @if (order.IsCompleted)
                    {
                        <span class="badge bg-success">Done</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">In progress</span>
                    }
                </td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@order.Id">Details</a>
                    @if (isTrusted)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@order.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@order.Id">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No repair orders found.</p>
}

<partial name="_PaginationPartial" />
