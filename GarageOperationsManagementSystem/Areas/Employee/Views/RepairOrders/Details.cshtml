@model GarageOperationsManagementSystem.Models.RepairOrder

@{
    ViewData["Title"] = "Repair order details";
}

<h2 class="mb-3">Repair order details</h2>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.Id</dd>
    <dt class="col-sm-3">Issue code</dt>
    <dd class="col-sm-9"><code>@Model.IssueCode</code></dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.IssueDescription</dd>
    <dt class="col-sm-3">Arrival</dt>
    <dd class="col-sm-9">@Model.ArrivalDate.ToString("yyyy-MM-dd HH:mm")</dd>
    <dt class="col-sm-3">Completion</dt>
    <dd class="col-sm-9">@(Model.CompletionDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.IsCompleted ? "Completed" : "In progress")</dd>
    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@(Model.RepairPrice?.ToString("F2") ?? "—")</dd>
    <dt class="col-sm-3">Car</dt>
    <dd class="col-sm-9">@(Model.Car != null ? $"{Model.Car.Brand} {Model.Car.Model}" : "—")</dd>
    <dt class="col-sm-3">Owner</dt>
    <dd class="col-sm-9">@(Model.Car?.Owner?.FullName ?? "—")</dd>
    <dt class="col-sm-3">Garage</dt>
    <dd class="col-sm-9">@(Model.Garage != null ? $"{Model.Garage.City}, {Model.Garage.Address}" : "—")</dd>
</dl>

@if (!Model.IsCompleted)
{
    <div class="card mb-4">
        <div class="card-body">
            <h3 class="h6">Mark as completed</h3>
            <form asp-action="Complete" method="post" class="row g-2 align-items-end">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="col-auto">
                    <label for="repairPrice" class="form-label">Final price</label>
                    <input id="repairPrice" name="repairPrice" type="number" step="0.01" min="0" required class="form-control" style="width: 12rem;" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success">Complete order</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="mt-3">
    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-outline-secondary ms-2" asp-action="Index">Back to list</a>
</div>
