@model AdminCarFormViewModel

@{
    ViewData["Title"] = "Create car";
}

<h2 class="mb-3">Create car</h2>

@if (TempData["Message"] is string msg && !string.IsNullOrEmpty(msg))
{
    <p class="alert alert-warning">@msg</p>
}

@if (ViewBag.OwnerCount is int oc && oc == 0)
{
    <p class="alert alert-danger">
        There are no owners yet. Create an owner first:
        <a asp-area="Employee" asp-controller="Owners" asp-action="Create">Add owner</a>.
    </p>
}

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-2">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
        <span asp-validation-for="Brand" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" />
        <span asp-validation-for="Model" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Mileage" class="form-label"></label>
        <input asp-for="Mileage" class="form-control" />
        <span asp-validation-for="Mileage" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="OwnerId" class="form-label"></label>
        <select asp-for="OwnerId" asp-items="ViewBag.OwnerId" class="form-select"></select>
        <div class="form-text">Pick the owner from the list. Create the owner under Owners if missing.</div>
        <span asp-validation-for="OwnerId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
</form>

<p class="mt-3"><a asp-action="Index">Back to list</a></p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
