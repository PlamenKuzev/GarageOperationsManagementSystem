@model AdminCarFormViewModel

@{
    ViewData["Title"] = "Add car";
}

<div class="mb-4">
    <h1 class="h3">Add car</h1>
</div>

@if (ViewBag.OwnerCount is int oc && oc == 0)
{
    <div class="alert alert-warning">
        No owners exist yet. <a asp-area="Employee" asp-controller="Owners" asp-action="Create">Add an owner first</a>.
    </div>
}

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <div class="mb-3">
                <label asp-for="Brand" class="form-label"></label>
                <input asp-for="Brand" class="form-control" />
                <span asp-validation-for="Brand" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Model" class="form-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Year" class="form-label"></label>
                <input asp-for="Year" class="form-control" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Mileage" class="form-label"></label>
                <input asp-for="Mileage" class="form-control" />
                <span asp-validation-for="Mileage" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="OwnerId" class="form-label"></label>
                <select asp-for="OwnerId" asp-items="ViewBag.OwnerId" class="form-select">
                    <option value="">— Select owner —</option>
                </select>
                <span asp-validation-for="OwnerId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Add car</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
