@model GarageOperationsManagementSystem.Models.Car

@{
    ViewData["Title"] = "Delete car";
}

<div class="mb-4">
    <h1 class="h3">Delete car</h1>
    <p class="text-muted mb-0">This action cannot be undone.</p>
</div>

<div class="card border-danger" style="max-width: 460px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8">@Model.Brand</dd>

            <dt class="col-sm-4">Model</dt>
            <dd class="col-sm-8">@Model.Model</dd>

            <dt class="col-sm-4">Owner</dt>
            <dd class="col-sm-8">@(Model.Owner?.FullName ?? "—")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
