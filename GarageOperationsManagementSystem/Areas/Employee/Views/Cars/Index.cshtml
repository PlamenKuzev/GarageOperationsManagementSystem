@model IEnumerable<GarageOperationsManagementSystem.Models.Car>

@{
    ViewData["Title"] = "Cars";
    var isTrusted = (bool)(ViewData["IsTrusted"] ?? false);
}

<div class="mb-4">
    <h1 class="h3">Cars</h1>
    <p class="text-muted mb-0">All vehicles registered in the system.</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">@Model.Count() car(s) total</span>
    <a asp-action="Create" class="btn btn-primary">Add car</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Brand</th>
            <th>Model</th>
            <th>Year</th>
            <th>Mileage</th>
            <th>Owner</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var car in Model)
        {
            <tr>
                <td class="fw-semibold">@car.Brand</td>
                <td>@car.Model</td>
                <td>@car.Year</td>
                <td>@(car.Mileage.HasValue ? $"{car.Mileage.Value:N0} km" : "—")</td>
                <td>@(car.Owner?.FullName ?? "—")</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@car.Id">Details</a>
                    @if (isTrusted)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@car.Id">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@car.Id">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No cars yet.</p>
}
