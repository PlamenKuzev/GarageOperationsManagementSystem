@model GarageOperationsManagementSystem.Models.Employee?

@{
    ViewData["Title"] = "Employee workspace";
    var emp = Model;
    var garage = emp?.Garage;
    var isTrusted = emp?.IsTrusted ?? false;
}

<h1 class="display-6 fw-semibold mb-4">Welcome, @(emp?.Name ?? "Employee")!</h1>

@* Profile card *@
@if (emp != null)
{
    <div class="card mb-4 shadow-sm" style="border-left: 4px solid #0d6efd;">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-2">
                <div>
                    <h2 class="h4 mb-0">@emp.Name</h2>
                    <span class="badge @(emp.IsTrusted ? "bg-success" : "bg-secondary") mt-1">@emp.Position</span>
                </div>
            </div>
            <dl class="row mb-0 mt-2">
                <dt class="col-sm-3">Garage</dt>
                <dd class="col-sm-9">@emp.Garage?.City — @emp.Garage?.Address</dd>

                <dt class="col-sm-3">Monthly Salary</dt>
                <dd class="col-sm-9">@emp.Salary.ToString("F0") EUR</dd>

                <dt class="col-sm-3">Working Since</dt>
                <dd class="col-sm-9">@emp.WorkingSince.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">Access Level</dt>
                <dd class="col-sm-9">
                    @if (emp.IsTrusted)
                    {
                        <span class="text-success fw-semibold">Trusted — full access</span>
                    }
                    else
                    {
                        <span class="text-secondary">Junior — view &amp; create only (own garage)</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mb-4">
        Your employee profile has not been linked yet. Please contact an administrator.
    </div>
}

@* Garage section *@
@if (garage != null)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">My Garage</span>
            @if (isTrusted)
            {
                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#garageEditForm">
                    Edit
                </button>
            }
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@garage.City</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@garage.Address</dd>

                <dt class="col-sm-3">Capacity</dt>
                <dd class="col-sm-9">@garage.Capacity</dd>

                <dt class="col-sm-3">Work Schedule</dt>
                <dd class="col-sm-9">@garage.WorkSchedule</dd>
            </dl>
        </div>

        @if (isTrusted)
        {
            <div class="collapse" id="garageEditForm">
                <div class="card-footer">
                    <form asp-area="Employee" asp-controller="Home" asp-action="EditGarage" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="garageId" value="@garage.Id" />
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label">City</label>
                                <input type="text" name="city" class="form-control" value="@garage.City" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Address</label>
                                <input type="text" name="address" class="form-control" value="@garage.Address" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Capacity</label>
                                <input type="number" name="capacity" class="form-control" value="@garage.Capacity" min="1" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Work Schedule</label>
                                <input type="text" name="workSchedule" class="form-control" value="@garage.WorkSchedule" required />
                            </div>
                            <div class="col-12 mt-1">
                                <button type="submit" class="btn btn-primary btn-sm">Save changes</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
}

<h5 class="text-muted mb-3">Quick Actions</h5>
<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Repair Orders</h2>
                <p class="card-text text-muted small">Create, update, complete, delete repair orders.</p>
                <a class="btn btn-primary mt-auto" asp-area="Employee" asp-controller="RepairOrders" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Cars</h2>
                <p class="card-text text-muted small">Register and maintain vehicles.</p>
                <a class="btn btn-primary mt-auto" asp-area="Employee" asp-controller="Cars" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Owners</h2>
                <p class="card-text text-muted small">Manage customer records.</p>
                <a class="btn btn-primary mt-auto" asp-area="Employee" asp-controller="Owners" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
</div>
