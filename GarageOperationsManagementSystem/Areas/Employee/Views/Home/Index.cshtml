@{
    ViewData["Title"] = "Employee workspace";
}

<div class="mb-4">
    <h1 class="display-6">Employee workspace</h1>
    <p class="text-muted mb-0">Manage repair orders, cars, and owners.</p>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Repair orders</h2>
                <p class="card-text text-muted small">Create, update, complete, delete repair orders.</p>
                <a class="btn btn-primary" asp-area="Employee" asp-controller="RepairOrders" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Cars</h2>
                <p class="card-text text-muted small">Register and maintain vehicles.</p>
                <a class="btn btn-primary" asp-area="Employee" asp-controller="Cars" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h2 class="h5 card-title">Owners</h2>
                <p class="card-text text-muted small">Manage customer records.</p>
                <a class="btn btn-primary" asp-area="Employee" asp-controller="Owners" asp-action="Index">Open</a>
            </div>
        </div>
    </div>
</div>
