@using Microsoft.AspNetCore.Identity
@using GarageOperationsManagementSystem.Models
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Admin dashboard";
    var appUser = await UserManager.GetUserAsync(User);
    var displayName = appUser?.FullName is { Length: > 0 }
        ? appUser.FullName
        : appUser?.Email?.Split('@')[0];
}

<h1 class="display-6 fw-semibold mb-1">Welcome, @displayName!</h1>
<p class="text-muted mb-4">Choose a section to manage.</p>

<h6 class="text-muted text-uppercase fw-semibold mb-2">Profiles</h6>
<div class="row g-3 justify-content-center mb-4">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Owners</h2>
                <p class="card-text text-muted small">Customer records for vehicles.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Owners" asp-action="Index">Manage owners</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Employees</h2>
                <p class="card-text text-muted small">Create accounts and manage staff records.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Employees" asp-action="Index">Manage employees</a>
            </div>
        </div>
    </div>
</div>

<h6 class="text-muted text-uppercase fw-semibold mb-2">Models</h6>
<div class="row g-3 pb-5">
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Garages</h2>
                <p class="card-text text-muted small">Locations and capacity.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Garages" asp-action="Index">Manage garages</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Cars</h2>
                <p class="card-text text-muted small">Create and edit vehicles and owners.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Cars" asp-action="Index">Manage cars</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Repair orders</h2>
                <p class="card-text text-muted small">Work orders and issue codes.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="RepairOrders" asp-action="Index">Manage repair orders</a>
            </div>
        </div>
    </div>
</div>
