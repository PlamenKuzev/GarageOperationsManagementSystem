@{
    ViewData["Title"] = "Admin dashboard";
}

<div class="mb-4">
    <h1 class="h3">Admin dashboard</h1>
    <p class="text-muted mb-0">Choose a section to manage.</p>
</div>

<div class="row g-3 pb-5">
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Cars</h2>
                <p class="card-text text-muted small">Create and edit vehicles and owners.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Cars" asp-action="Index">Manage cars</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Repair orders</h2>
                <p class="card-text text-muted small">Work orders and issue codes.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="RepairOrders" asp-action="Index">Manage repair orders</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Owners</h2>
                <p class="card-text text-muted small">Customer records for vehicles.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Owners" asp-action="Index">Manage owners</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h2 class="h5 card-title">Garages</h2>
                <p class="card-text text-muted small">Locations and capacity.</p>
                <a class="btn btn-primary mt-auto" asp-area="Admin" asp-controller="Garages" asp-action="Index">Manage garages</a>
            </div>
        </div>
    </div>
</div>