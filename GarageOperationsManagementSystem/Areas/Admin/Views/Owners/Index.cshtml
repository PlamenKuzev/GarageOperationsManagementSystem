@model IEnumerable<GarageOperationsManagementSystem.Models.Owner>

@{
    ViewData["Title"] = "Owners";
}

<div class="mb-4">
    <h1 class="h3">Owners</h1>
    <p class="text-muted mb-0">Car owners registered in the system.</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">@Model.Count() owner(s) total</span>
    <a asp-action="Create" class="btn btn-primary">Add owner</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Full name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Cars</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td class="fw-semibold">@o.FullName</td>
                <td>@o.Email</td>
                <td>@o.PhoneNumber</td>
                <td><span class="badge bg-secondary">@o.Cars.Count</span></td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@o.Id">Details</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@o.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@o.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No owners yet.</p>
}
