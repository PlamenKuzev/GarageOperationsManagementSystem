@model PaginatedList<GarageOperationsManagementSystem.Models.Garage>

@{
    ViewData["Title"] = "Garages";
}

<div class="mb-4">
    <h1 class="h3">Garages</h1>
    <p class="text-muted mb-0">Locations and capacity.</p>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <partial name="_SearchFormPartial" />
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Create">Add garage</a>
        <form asp-action="LoadDemoData" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary">Load demo data</button>
        </form>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>City</th>
            <th>Address</th>
            <th>Capacity</th>
            <th>Schedule</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td>@g.City</td>
                <td>@g.Address</td>
                <td>@g.Capacity</td>
                <td>@g.WorkSchedule</td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@g.Id">Details</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@g.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@g.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-muted">No garages found.</p>
}

<partial name="_PaginationPartial" />
