@model GarageOperationsManagementSystem.Models.Garage

<h2>Edit garage</h2>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-2">
        <label asp-for="City" class="form-label"></label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Capacity" class="form-label"></label>
        <input asp-for="Capacity" class="form-control" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="WorkSchedule" class="form-label"></label>
        <input asp-for="WorkSchedule" class="form-control" />
        <span asp-validation-for="WorkSchedule" class="text-danger"></span>
    </div>
    @{ ViewData["InitLat"] = Model.Latitude; ViewData["InitLng"] = Model.Longitude; }
    <partial name="_MapPickerPartial" />

    <button type="submit" class="btn btn-primary">Save</button>
</form>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
