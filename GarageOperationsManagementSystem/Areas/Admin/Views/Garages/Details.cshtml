@model GarageOperationsManagementSystem.Models.Garage

@{
    ViewData["Title"] = $"Garage — {Model.City}";
}

<div class="mb-4">
    <h1 class="h3">@Model.City — @Model.Address</h1>
    <p class="text-muted mb-0">Garage details</p>
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-5">City</dt>
            <dd class="col-sm-7">@Model.City</dd>

            <dt class="col-sm-5">Address</dt>
            <dd class="col-sm-7">@Model.Address</dd>

            <dt class="col-sm-5">Capacity</dt>
            <dd class="col-sm-7">@Model.Capacity</dd>

            <dt class="col-sm-5">Work schedule</dt>
            <dd class="col-sm-7">@(Model.WorkSchedule ?? "—")</dd>

            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <dt class="col-sm-5">Coordinates</dt>
                <dd class="col-sm-7">@Model.Latitude.Value.ToString("F4"), @Model.Longitude.Value.ToString("F4")</dd>
            }
        </dl>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-outline-secondary ms-2" asp-action="Index">Back to list</a>
</div>
