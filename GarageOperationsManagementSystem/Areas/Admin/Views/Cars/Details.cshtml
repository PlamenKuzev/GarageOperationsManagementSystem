@model GarageOperationsManagementSystem.Models.Car

@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
}

<div class="mb-4">
    <h1 class="h3">@Model.Brand @Model.Model</h1>
    <p class="text-muted mb-0">Vehicle details</p>
</div>

<div class="card" style="max-width: 460px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Brand</dt>
            <dd class="col-sm-8">@Model.Brand</dd>

            <dt class="col-sm-4">Model</dt>
            <dd class="col-sm-8">@Model.Model</dd>

            <dt class="col-sm-4">Year</dt>
            <dd class="col-sm-8">@Model.Year</dd>

            <dt class="col-sm-4">Mileage</dt>
            <dd class="col-sm-8">@(Model.Mileage.HasValue ? $"{Model.Mileage.Value:N0} km" : "—")</dd>

            <dt class="col-sm-4">Owner</dt>
            <dd class="col-sm-8">@(Model.Owner?.FullName ?? "—")</dd>

            <dt class="col-sm-4">Owner email</dt>
            <dd class="col-sm-8">@(Model.Owner?.Email ?? "—")</dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-outline-secondary ms-2" asp-action="Index">Back to list</a>
</div>
