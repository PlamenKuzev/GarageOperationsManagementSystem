@model GarageOperationsManagementSystem.ViewModels.Admin.EditEmployeeViewModel

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h2 class="mb-4">Edit Employee</h2>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Position" class="form-label"></label>
                    <input asp-for="Position" class="form-control" />
                    <span asp-validation-for="Position" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Salary" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Salary" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="Salary" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="WorkingSince" class="form-label"></label>
                    <input asp-for="WorkingSince" class="form-control" type="date" />
                    <span asp-validation-for="WorkingSince" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="GarageId" class="form-label"></label>
                    <select asp-for="GarageId" asp-items="ViewBag.GarageId" class="form-select">
                        <option value="">— Select garage —</option>
                    </select>
                    <span asp-validation-for="GarageId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsTrusted" class="form-check-input" type="checkbox" />
                <label asp-for="IsTrusted" class="form-check-label"></label>
                <div class="form-text">Trusted employees can edit and delete records.</div>
            </div>

            <div class="alert alert-info small">
                <strong>Note:</strong> Login credentials (email/password) cannot be changed here. Contact the system administrator to reset the password directly.
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
