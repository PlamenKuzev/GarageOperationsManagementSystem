@model IEnumerable<GarageOperationsManagementSystem.ViewModels.Admin.EmployeeIndexViewModel>

@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Employees</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add Employee
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No employees found. Use the button above to add the first one.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Position</th>
                    <th>Garage</th>
                    <th>Salary</th>
                    <th>Working Since</th>
                    <th>Status</th>
                    <th>Account</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="fw-semibold">@emp.Name</td>
                        <td>@emp.Position</td>
                        <td>@emp.GarageName</td>
                        <td>@emp.Salary.ToString("C0")</td>
                        <td>@emp.WorkingSince.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (emp.IsTrusted)
                            {
                                <span class="badge bg-success">Trusted</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Junior</span>
                            }
                        </td>
                        <td>
                            @if (emp.LinkedEmail != null)
                            {
                                <span class="badge bg-primary">
                                    <i class="bi bi-link-45deg"></i> @emp.LinkedEmail
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">No account</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
