@model PaginatedList<GarageOperationsManagementSystem.ViewModels.Admin.EmployeeIndexViewModel>

@{
    ViewData["Title"] = "Employees";
}

<div class="mb-4">
    <h1 class="h3">Employees</h1>
    <p class="text-muted mb-0">All staff members and their linked accounts.</p>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <partial name="_SearchFormPartial" />
    <a asp-action="Create" class="btn btn-primary">Add employee</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No employees found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Position</th>
                    <th>Garage</th>
                    <th>Salary</th>
                    <th>Working Since</th>
                    <th>Access</th>
                    <th>Account</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td class="fw-semibold">@emp.Name</td>
                        <td>@emp.Position</td>
                        <td>@emp.GarageName</td>
                        <td>@emp.Salary.ToString("C0")</td>
                        <td>@emp.WorkingSince.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (emp.IsTrusted)
                            {
                                <span class="badge bg-success">Trusted</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Junior</span>
                            }
                        </td>
                        <td>
                            @if (emp.LinkedEmail != null)
                            {
                                <span class="badge bg-primary">@emp.LinkedEmail</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">No account</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<partial name="_PaginationPartial" />
