@model GarageOperationsManagementSystem.ViewModels.Admin.CreateEmployeeViewModel

@{
    ViewData["Title"] = "Add Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h2 class="mb-4">Add Employee</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <h5 class="text-muted mb-3">Employee Details</h5>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. John Smith" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Position" class="form-label"></label>
                    <input asp-for="Position" class="form-control" placeholder="e.g. Mechanic" />
                    <span asp-validation-for="Position" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Salary" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Salary" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <span asp-validation-for="Salary" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="WorkingSince" class="form-label"></label>
                    <input asp-for="WorkingSince" class="form-control" type="date" />
                    <span asp-validation-for="WorkingSince" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="GarageId" class="form-label"></label>
                    <select asp-for="GarageId" asp-items="ViewBag.GarageId" class="form-select">
                        <option value="">— Select garage —</option>
                    </select>
                    <span asp-validation-for="GarageId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsTrusted" class="form-check-input" type="checkbox" />
                <label asp-for="IsTrusted" class="form-check-label"></label>
                <div class="form-text">Trusted employees can edit and delete records. Untrusted employees can only create and view their own garage's orders.</div>
            </div>

            <hr class="my-4" />
            <h5 class="text-muted mb-3">Login Account</h5>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" placeholder="e.g. employee@garage.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Create Employee</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
