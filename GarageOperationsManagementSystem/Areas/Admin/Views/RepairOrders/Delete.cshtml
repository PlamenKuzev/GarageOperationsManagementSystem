@model GarageOperationsManagementSystem.Models.RepairOrder

<h2>Delete Repair Order</h2>

<p>Are you sure you want to delete this repair order?</p>

<ul>
    <li>Id: @Model.Id</li>
    <li>Issue Code: @Model.IssueCode</li>
    <li>Issue Description: @Model.IssueDescription</li>
</ul>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>