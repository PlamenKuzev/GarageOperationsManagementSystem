@model GarageOperationsManagementSystem.Models.RepairOrder

@{
    ViewData["Title"] = $"Repair order #{Model.Id}";
}

<div class="mb-4">
    <h1 class="h3">Repair order <code>@Model.IssueCode</code></h1>
    <p class="text-muted mb-0">
        @if (Model.IsCompleted)
        {
            <span class="badge bg-success">Completed</span>
        }
        else
        {
            <span class="badge bg-warning text-dark">In progress</span>
        }
    </p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Issue details</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Issue code</dt>
                    <dd class="col-sm-7"><code>@Model.IssueCode</code></dd>

                    <dt class="col-sm-5">Description</dt>
                    <dd class="col-sm-7">@(Model.IssueDescription ?? "—")</dd>

                    <dt class="col-sm-5">Arrival date</dt>
                    <dd class="col-sm-7">@Model.ArrivalDate.ToString("dd MMM yyyy")</dd>

                    <dt class="col-sm-5">Completion date</dt>
                    <dd class="col-sm-7">@(Model.CompletionDate.HasValue ? Model.CompletionDate.Value.ToString("dd MMM yyyy") : "—")</dd>

                    <dt class="col-sm-5">Repair price</dt>
                    <dd class="col-sm-7">@(Model.RepairPrice.HasValue ? $"{Model.RepairPrice.Value:F2} EUR" : "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Car & garage</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Car</dt>
                    <dd class="col-sm-7">@Model.Car?.Brand @Model.Car?.Model</dd>

                    <dt class="col-sm-5">Owner</dt>
                    <dd class="col-sm-7">@(Model.Car?.Owner?.FullName ?? "—")</dd>

                    <dt class="col-sm-5">Garage</dt>
                    <dd class="col-sm-7">@(Model.Garage != null ? $"{Model.Garage.City} — {Model.Garage.Address}" : "—")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-outline-secondary ms-2" asp-action="Index">Back to list</a>
</div>
